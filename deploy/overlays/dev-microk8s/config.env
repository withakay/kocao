CP_ENV=dev

# Allow GitHub egress in restricted mode (GitHub's published CIDR prefixes).
CP_GITHUB_EGRESS_CIDRS=140.82.112.0/20,143.55.64.0/20,185.199.108.0/22,192.30.252.0/22,20.26.156.0/24,4.208.26.0/24
CP_BOOTSTRAP_TOKEN=dev-bootstrap
CP_AUDIT_PATH=/tmp/kocao.audit.jsonl

# Sidecar image override for GHCR (cluster can't pull local images)
KOCAO_SIDECAR_IMAGE=ghcr.io/withakay/kocao/kocao-sidecar:dev-microk8s
